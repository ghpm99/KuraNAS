<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/list_item_height_two_line"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/spacing_md"
    android:paddingRight="@dimen/spacing_md"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/video_thumbnail"
        android:layout_width="80dp"
        android:layout_height="@dimen/thumbnail_size"
        android:scaleType="centerCrop"
        android:background="@color/surface"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="@dimen/spacing_sm">

        <TextView
            android:id="@+id/video_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/on_primary"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/video_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_secondary"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
