<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/content_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome"
                    android:textSize="@dimen/text_title"
                    android:textColor="@color/on_primary"
                    android:padding="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/section_recent_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_files"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/accent"
                        android:paddingLeft="@dimen/spacing_md"
                        android:paddingRight="@dimen/spacing_md"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recent_files_list"
                        android:layout_width="match_parent"
                        android:layout_height="120dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/section_starred_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/starred"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/accent"
                        android:paddingLeft="@dimen/spacing_md"
                        android:paddingRight="@dimen/spacing_md"
                        android:paddingTop="@dimen/spacing_sm"
                        android:paddingBottom="@dimen/spacing_sm" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/starred_list"
                        android:layout_width="match_parent"
                        android:layout_height="120dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <include
        layout="@layout/view_state_loading"
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <include
        layout="@layout/view_state_empty"
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <include
        layout="@layout/view_state_error"
        android:id="@+id/error_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
