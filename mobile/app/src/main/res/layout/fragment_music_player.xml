<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary"
    android:padding="@dimen/spacing_lg">

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/album_art"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/spacing_md" />

    <TextView
        android:id="@+id/track_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_title"
        android:textColor="@color/on_primary"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/track_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_subtitle"
        android:textColor="@color/on_surface_secondary"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end" />

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/spacing_lg" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progressTint="@color/accent"
        android:thumbTint="@color/accent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="@dimen/spacing_sm">

        <TextView
            android:id="@+id/current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_secondary"
            android:text="0:00" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_secondary"
            android:text="0:00" />

    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/spacing_lg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_previous"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <View
            android:layout_width="@dimen/spacing_xl"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <View
            android:layout_width="@dimen/spacing_xl"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_skip_next"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
