<?xml version="1.0" encoding="utf-8"?>
<!-- One e-mail row: colour marker (verdict/importance) + sender + time, subject,
     and AI summary (hidden when absent or when the message is flagged). Plain
     TextViews only — e-mail content is never rendered as HTML. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingBottom="@dimen/spacing_sm">

    <View
        android:id="@+id/marker"
        android:layout_width="@dimen/kiosk_marker_width"
        android:layout_height="match_parent"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@color/surface" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/email_sender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/email_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/email_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/on_surface_secondary" />

        </LinearLayout>

        <TextView
            android:id="@+id/email_subject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/on_surface"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/email_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
