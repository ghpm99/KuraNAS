{
  "openapi": "3.0.3",
  "info": {
    "title": "KuraNAS API",
    "description": "API HTTP do backend KuraNAS.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Base path da API v1"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Verifica a saude da API",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "API saudavel",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "service"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "kuranas"
          }
        }
      }
    }
  }
}
